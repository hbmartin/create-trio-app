{
	"name": "create-trio-app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"bin": {
		"create-trio-app": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
		"check": "pnpm lint && pnpm typecheck && pnpm test",
		"dev": "tsx src/cli.ts",
		"format": "biome check --write .",
		"lint": "biome check --error-on-warnings .",
		"test": "vitest run",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^24.12.2",
		"tsx": "^4.21.0",
		"typescript": "6.0.2",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.30.2"
}
