{
	"name": "create-trio-app",
	"version": "0.1.0",
	"description": "CLI generator for production-oriented Next.js modular-monolith projects.",
	"keywords": [
		"create",
		"nextjs",
		"typescript",
		"generator",
		"modular-monolith"
	],
	"homepage": "https://github.com/hbmartin/create-trio-app#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hbmartin/create-trio-app.git"
	},
	"bugs": {
		"url": "https://github.com/hbmartin/create-trio-app/issues"
	},
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"create-trio-app": "./dist/cli.js"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"audit:prod": "pnpm audit --prod",
		"build": "tsdown && node scripts/postbuild.mjs",
		"check": "pnpm lint && pnpm typecheck && pnpm test && pnpm package:check",
		"dev": "tsx src/cli.ts",
		"format": "biome check --write .",
		"lint": "biome check --error-on-warnings .",
		"package:check": "pnpm build && publint && attw --pack . --profile esm-only",
		"pack:dry-run": "npm pack --dry-run",
		"prepublishOnly": "pnpm check",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^24.12.2",
		"@vitest/coverage-v8": "^4.1.5",
		"publint": "^0.3.18",
		"tsdown": "^0.21.10",
		"tsx": "^4.21.0",
		"typescript": "6.0.2",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.30.2"
}
